<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>
  
  <!-- This property is used by Cucumber.CCK as destination of the content files (e.g. .feature, .ndjson) for the tests. -->
  <PropertyGroup>
    <CucumberCCKContentPath>CCK\Resources</CucumberCCKContentPath>
  </PropertyGroup>
  
  <!-- Binding classes for scenarios come from the Samples\Resources tree.
        This tree also includes feature files and other assets for non-CCK scenarios. -->
  <ItemGroup>
    <Compile Remove="Samples\Resources\**\*.cs" />
    <EmbeddedResource Include="Samples\Resources\**\*.*" />
  </ItemGroup>

  <!-- This target embeds the feature files and other assets delivered by the Cucumber.CCK package. -->
  <Target Name="MakeCCKContentEmbeddedResource"
          AfterTargets="ResolvePackageAssets"
          BeforeTargets="CoreCompile">
    <ItemGroup>
      <_CCKContent Include="@(Content)"
                   Condition="$([System.String]::Copy('%(Link)').StartsWith('$(CucumberCCKContentPath)\'))" />
      <Content Remove="@(_CCKContent)" />
      <!-- Compute LogicalName on _CCKContent (all items have Link) before transferring to EmbeddedResource -->
      <_CCKContent Update="@(_CCKContent)">
        <LogicalName>$(RootNamespace).$([System.String]::Copy('%(Link)').Replace('\','.').Replace('/','.').Replace('-','_'))</LogicalName>
      </_CCKContent>
      <EmbeddedResource Include="@(_CCKContent)" />
    </ItemGroup>
  </Target>
  
  <ItemGroup>
    <PackageReference Include="Cucumber.CCK" Version="29.1.4" />
    <PackageReference Include="GitHubActionsTestLogger" Version="2.4.1" Condition="'$(REQNROLL_TEST_PIPELINEMODE)' == 'true'">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector" Version="6.0.0" />
    <PackageReference Include="FluentAssertions" Version="7.2.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.10.2" />
    <PackageReference Include="MSTest.TestFramework" Version="3.10.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Plugins\Reqnroll.ExternalData\Reqnroll.ExternalData.ReqnrollPlugin\Reqnroll.ExternalData.ReqnrollPlugin.csproj">
      <PrivateAssets>all</PrivateAssets>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
    <ProjectReference Include="..\..\Reqnroll.Utils\Reqnroll.Utils.csproj" />
    <ProjectReference Include="..\..\Reqnroll\Reqnroll.csproj" />
    <ProjectReference Include="..\Reqnroll.SystemTests\Reqnroll.SystemTests.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.VisualStudio.TestTools.UnitTesting" />
  </ItemGroup>

  <ItemGroup>
    <None Update="reqnroll_withBothFormatters.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="reqnroll_withHtmlOutput.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="reqnrollConfigurationWithExternalAssembly.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="reqnroll.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="partialConfiguration.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Samples\CucumberMessages\" />
  </ItemGroup>

</Project>
